# ===========================================
# Multilingual RAG System — Environment Config
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# LLM Generation Configuration
# Choose one of: ollama, groq, openai, google
# ===========================================
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2:3b

# API Keys (only required for the provider you choose)
OLLAMA_BASE_URL= "OLLAMA_BASE_URL"
# GROQ_API_KEY=gsk_your_groq_api_key_here
# OPENAI_API_KEY=sk-your_openai_api_key_here
 
# ===========================================
# Embedding Configuration
# ===========================================
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# Data Configuration
DATASET_PATH=Natural-Questions-Base.csv
SAMPLE_SIZE=10000
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# FAISS Configuration
INDEX_DIR=index_data
TOP_K=5

# Database
DATABASE_URL=sqlite:///rag_system.db

# Cache
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# API
API_HOST=0.0.0.0
API_PORT=8000